// DPP PIM data model
// Product is the core entity, carrying the material composition and
// supply chain information required for the Digital Product Passport

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model Product {
    id       String @id @default(cuid())
    // Identifier used by the public DPP page, separate from the internal id
    publicId String @unique @default(uuid())

    // SQLite has no enum support, stored as string: DRAFT | PUBLISHED
    status String @default("DRAFT")

    // --- PIM basics ---
    name        String
    sku         String  @unique
    gtin        String?
    brand       String?
    category    String?
    description String?
    imageUrl    String?

    // --- DPP sustainability data ---
    countryOfOrigin    String?
    carbonFootprintKg  Float? // carbon footprint (kg CO2e)
    recyclabilityPct   Float? // recyclable share 0-100
    durabilityYears    Int? // expected lifetime in years
    repairabilityScore Float? // repairability score 0-10
    careInstructions   String?
    certifications     String? // comma-separated, kept simple for the MVP

    materials   Material[]
    supplyChain SupplyChainStep[]

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    publishedAt DateTime?

    @@index([status])
    @@index([name])
}

model Material {
    id         String  @id @default(cuid())
    productId  String
    product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    name       String
    percentage Float // share 0-100
    recycled   Boolean @default(false)
    origin     String?

    @@index([productId])
}

model SupplyChainStep {
    id          String  @id @default(cuid())
    productId   String
    product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    order       Int // step order
    stage       String // e.g. Raw Material / Manufacturing / Assembly / Distribution
    facility    String?
    location    String?
    description String?

    @@index([productId])
}
